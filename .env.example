# IT/OT Incident Response System - Environment Configuration
# Copy this file to .env and update as needed.
# NEVER commit .env to version control.

# Flask configuration
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Database (SQLite default, change to PostgreSQL for production)
DATABASE_URL=sqlite:///data/incidents.db

# Alert ingestion directory
ALERTS_DIR=data/alerts

# OT asset context
ASSETS_FILE=data/ot_context/ot_assets.json

# Rule and dependency config
RULES_FILE=config/rules.json
DEPENDENCIES_FILE=config/dependencies.json

# Alert history cap
ALERT_HISTORY_LIMIT=1000

# Brute force detection thresholds
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW_MINUTES=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/app.log

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Optional: Comma-separated list of device IPs to monitor
# MONITORED_DEVICES=192.168.1.10,192.168.1.11
